{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase2.DomFilter",
  "type": "object",
  "required": ["filtered_dom"],
  "properties": {
    "filtered_dom": {"type": "string"},
    "rationale": {"type": "string"},
    "candidate_locators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["strategy", "selector"],
        "properties": {
          "strategy": {"enum": ["id", "name", "data-test-id", "css", "xpath", "aria-label", "role"]},
          "selector": {"type": "string"},
          "score": {"type": "number"}
        }
      }
    }
  }
}
