{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase1.Structuring",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "steps"],
        "properties": {
          "id": {"type": "integer"},
          "title": {"type": "string"},
          "steps": {"type": "array", "items": {"type": "string"}},
          "input_bindings": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
