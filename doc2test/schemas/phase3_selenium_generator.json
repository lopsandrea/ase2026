{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase3.SeleniumGenerator",
  "type": "object",
  "required": ["code"],
  "properties": {
    "code": {"type": "string", "minLength": 1},
    "locator_strategy": {"type": "string"},
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "expression"],
        "properties": {
          "category": {"enum": ["structural", "content", "navigation"]},
          "expression": {"type": "string"}
        }
      }
    },
    "explicit_waits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition", "selector"],
        "properties": {
          "condition": {"type": "string"},
          "selector": {"type": "string"}
        }
      }
    }
  }
}
