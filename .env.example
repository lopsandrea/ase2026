# Doc2Test environment variables (copy to .env and fill in)

# OpenAI - GPT-5 for Phase 1 and Phase 3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-0326-2026

# Google Vertex AI / Gemini - Phase 2 (DOM Filter Agent)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro-preview-03-25

# Sampling parameters (paper §4.1)
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.95

# Self-healing retry budget (paper Algorithm 1)
DOC2TEST_MAX_RETRIES=3

# Cache directory for deterministic replay
DOC2TEST_CACHE_DIR=~/.doc2test/cache

# Set to 1 to disable live API calls and only replay from cache
DOC2TEST_OFFLINE=0

# Selenium grid endpoint
SELENIUM_GRID_URL=http://localhost:4444/wd/hub
