<% const body = sent
  ? `<h1>Contact</h1><p data-test-id="contact-sent">Thanks, we will reply soon.</p>`
  : `<h1>Contact</h1><form method="post" action="/contact"><input id="contact-name" name="name" placeholder="Name"/><input id="contact-email" name="email" placeholder="Email"/><textarea id="contact-message" name="message" placeholder="Message"></textarea><button id="contact-submit" type="submit">Send</button></form>`;
%><%- include("_layout", { body, user: locals.user, title: "Contact" }) %>
